{
  "name": "handshake",
  "version": "0.1.0",
  "description": "Handshake — CAP Integration Auditor. A paid, CAP-callable agent that audits other agents' CAP integrations and issues signed attestations.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc && node -e \"require('fs').copyFileSync('src/db/schema.sql','dist/db/schema.sql')\"",
    "typecheck": "tsc --noEmit",
    "keygen": "tsx scripts/keygen.ts"
  },
  "dependencies": {
    "@croo-network/sdk": "^0.2.0",
    "@hono/node-server": "^1.13.0",
    "@noble/ed25519": "^2.1.0",
    "better-sqlite3": "^12.11.1",
    "ethers": "^6.13.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
